            text-align: center !important;
        }
        .katex-display {
            overflow: visible !important;
            padding: 0.25em 0.35em 0.75em 0.9em !important;
            margin: 1em 0 !important;
            text-align: center !important;
        }
        .katex-display > .katex {
            overflow: visible !important;
        }
        .katex-display > .katex > .katex-html {
